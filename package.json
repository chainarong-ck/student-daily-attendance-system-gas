{
    "name": "student-daily-attendance-system-gas",
    "version": "1.0.0",
    "description": "โปรเจกต์ Google Apps Script (Web App) สำหรับระบบบันทึกการเข้าเรียนรายวันของนักเรียน โดยใช้ Google Sheets เป็นแหล่งเก็บข้อมูล",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "clean": "node scripts/clean.mjs",
        "build:client": "node scripts/build-client.mjs",
        "build:server": "node scripts/build-server.mjs",
        "copy:assets": "node scripts/copy-assets.mjs",
        "build": "npm run typecheck && npm run clean && npm run build:client && npm run build:server && npm run copy:assets",
        "test:integration": "node --test tests/*.test.mjs",
        "test": "npm run build && npm run test:integration",
        "push": "clasp push",
        "deploy": "npm run build && clasp push"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/chainarong-ck/student-daily-attendance-system-gas.git"
    },
    "keywords": [],
    "author": "นายชัยณรงค์ คงพล (Chainarong-CK) <https://github.com/chainarong-ck>",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "bugs": {
        "url": "https://github.com/chainarong-ck/student-daily-attendance-system-gas/issues"
    },
    "homepage": "https://github.com/chainarong-ck/student-daily-attendance-system-gas#readme",
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.2",
        "@types/google-apps-script": "^2.0.11",
        "gas-webpack-plugin": "^2.6.0",
        "tailwindcss": "^4.3.2",
        "ts-loader": "^9.6.2",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vite-plugin-singlefile": "^2.3.3",
        "webpack": "^5.108.4"
    }
}
